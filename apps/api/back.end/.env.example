# Server
PORT=4000
NODE_ENV=production

# Auth
JWT_SECRET=
REFRESH_SECRET=

# Database (PostgreSQL — use Transaction pooler URL from Supabase, port 6543)
DATABASE_URL=

# CORS (set to your Netlify frontend URL — no trailing slash)
CORS_ORIGIN=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# URLs
FRONTEND_URL=
BACKEND_URL=

# Email (Resend — sign up at resend.com, verify domain or use sandbox)
RESEND_API_KEY=
# EMAIL_FROM defaults to onboarding@resend.dev (Resend sandbox — works without domain verification)
# In production, set this to your verified domain e.g. noreply@yourdomain.com
EMAIL_FROM=
